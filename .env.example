# Anthropic API Key for AI Analysis (optional - demo mode if not set)
ANTHROPIC_API_KEY=your-api-key-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (for Search Console integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth Secret for NextAuth v5 (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret
AUTH_URL=http://localhost:3000

# PostgreSQL Database (Neon/Supabase/any PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SERP API (serper.dev)
SERP_API_KEY=your-serper-api-key
SERP_API_PROVIDER=serper

# Cron Job Secret (protect cron endpoints)
CRON_SECRET=your-cron-secret

# Ahrefs Firehose (firehose.com) — real-time competitor monitoring
FIREHOSE_MANAGEMENT_KEY=fhm_your-management-key
FIREHOSE_TAP_TOKEN=fh_your-tap-token
FIREHOSE_WEBHOOK_SECRET=your-webhook-secret
