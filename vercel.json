{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx prisma db push --skip-generate && npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-ranking-history",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/detect-serp-movement",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/sync-competitor-snapshots",
      "schedule": "0 8 * * 1,3,5"
    },
    {
      "path": "/api/cron/generate-action-queue",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/poll-firehose",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/firehose/sync-rules",
      "schedule": "0 6 * * *"
    }
  ]
}
